# API 키 (LangSmith 설정 페이지에서 발급)
export LANGCHAIN_API_KEY=

# 프로젝트 이름 (LangSmith 대시보드에서 구분할 이름)
export LANGCHAIN_PROJECT="HR-Copilot" 

# (선택) 엔드포인트
export LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"